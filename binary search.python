numbers = [ 22, 33, 44, 55, 66, 77, 88, 99]
target = int(input("enter a number : "))
left = 0
right = len(numbers) - 1
found = False
while left <= right:
    mid = (right+left)//2
    if numbers[mid] == target:
        found = True
        break
    elif numbers[mid] < target:
        left = mid+1
    else:
        right = mid-1
if found:
    print("found");
else:
    print("not found");
